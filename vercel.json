{
  "version": 2,
  "buildCommand": "pnpm run build && pnpm exec esbuild api/index.ts --platform=node --packages=external --bundle --format=esm --outfile=api/index.mjs",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    }
  }
}
